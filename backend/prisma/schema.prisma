// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  passwordHash String       @map("password_hash")
  firstName    String?      @map("first_name")
  lastName     String?      @map("last_name")
  mustChangePassword Boolean @default(false) @map("must_change_password")
  passwordVersion    Int     @default(0) @map("password_version")
  disabledAt         DateTime? @map("disabled_at") @db.Timestamptz
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  memberships  Membership[]
  queries      Query[]
  dashboards   Dashboard[]
  executions   Execution[]
  auditLogs    AuditLog[]
  installation Installation? @relation("InstallationAdministrator")

  @@map("users")
}

model Organization {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  slug        String       @unique
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  memberships      Membership[]
  datasources      Datasource[]
  queries          Query[]
  dashboards       Dashboard[]
  executions       Execution[]
  auditLogs        AuditLog[]
  scheduledQueries ScheduledQuery[]
  installation     Installation?

  @@map("organizations")
}

model Installation {
  id                  Int       @id
  initializedAt       DateTime  @default(now()) @map("initialized_at") @db.Timestamptz
  organizationId      String?   @unique @map("organization_id") @db.Uuid
  administratorUserId String?   @unique @map("administrator_user_id") @db.Uuid

  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  administratorUser User?         @relation("InstallationAdministrator", fields: [administratorUserId], references: [id], onDelete: SetNull)

  @@map("installations")
}

enum Role {
  ADMIN
  EDITOR
  READER
}

model Membership {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  role           Role
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId], name: "unique_user_organization")
  @@map("memberships")
}

model Datasource {
  id                 String       @id @default(uuid()) @db.Uuid
  organizationId     String       @map("organization_id") @db.Uuid
  name               String
  type               String // postgres, mysql, sqlite, csv
  connectionSettings String       @map("connection_settings") // AES-256 Encrypted JSON
  accessPolicies     Json?        @map("access_policies") // { READER: { allowedColumns, rowFilter }, EDITOR: { ... } }
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  queries            Query[]

  @@map("datasources")
}

model Query {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  datasourceId   String?      @map("datasource_id") @db.Uuid
  name           String
  description    String?
  querySql       String       @map("query_sql")
  createdByUserId String?      @map("created_by_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  datasource       Datasource?      @relation(fields: [datasourceId], references: [id], onDelete: SetNull)
  createdByUser    User?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  widgets          Widget[]
  executions       Execution[]
  scheduledQueries ScheduledQuery[]

  @@map("queries")
}

model Dashboard {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  description    String?
  isPublic       Boolean      @default(false) @map("is_public")
  publishedAt    DateTime?    @map("published_at") @db.Timestamptz
  shareToken     String?      @unique @map("share_token")
  createdByUserId String?      @map("created_by_id") @db.Uuid
  config         Json?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser  User?        @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  pages          DashboardPage[]
  widgets        Widget[]

  @@map("dashboards")
}

model DashboardPage {
  id          String    @id @default(uuid()) @db.Uuid
  dashboardId String    @map("dashboard_id") @db.Uuid
  title       String
  slug        String
  icon        String?
  order       Int       @default(0)
  config      Json?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  widgets     Widget[]

  @@unique([dashboardId, slug])
  @@map("dashboard_pages")
}

model Widget {
  id          String    @id @default(uuid()) @db.Uuid
  dashboardId String    @map("dashboard_id") @db.Uuid
  pageId      String?   @map("page_id") @db.Uuid
  queryId     String?   @map("query_id") @db.Uuid
  title       String
  type        String    // table, bar, line, kpi, pie
  chartConfig Json      @map("chart_config")
  configVersion Int     @default(1) @map("config_version")
  dataConfig  Json?     @map("data_config")
  visualConfig Json?    @map("visual_config")
  interactionConfig Json? @map("interaction_config")
  layoutX     Int       @map("layout_x")
  layoutY     Int       @map("layout_y")
  layoutW     Int       @map("layout_w")
  layoutH     Int       @map("layout_h")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  page        DashboardPage? @relation(fields: [pageId], references: [id], onDelete: SetNull)
  query       Query?    @relation(fields: [queryId], references: [id], onDelete: SetNull)

  @@map("widgets")
}

model Execution {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  queryId        String?      @map("query_id") @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  sqlExecuted    String       @map("sql_executed")
  durationMs     Int          @map("duration_ms")
  rowCount       Int          @map("row_count")
  status         String       // success, error
  errorMessage   String?      @map("error_message")
  executedAt     DateTime     @default(now()) @map("executed_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  query          Query?       @relation(fields: [queryId], references: [id], onDelete: SetNull)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("executions")
}

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String?      @map("organization_id") @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  action         String
  resourceType   String       @map("resource_type")
  resourceId     String?      @map("resource_id")
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt], map: "audit_logs_org_created_at_idx")
  @@index([action, createdAt], map: "audit_logs_action_created_at_idx")
  @@map("audit_logs")
}

model ScheduledQuery {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  queryId        String            @map("query_id") @db.Uuid
  name           String
  cronExpression String            @map("cron_expression")
  recipients     String[]          // Array of emails
  enabled        Boolean           @default(true)
  subject        String?           // Custom email subject
  format         String            @default("csv") // csv, html, json
  lastRunAt      DateTime?         @map("last_run_at") @db.Timestamptz
  nextRunAt      DateTime?         @map("next_run_at") @db.Timestamptz
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  query          Query             @relation(fields: [queryId], references: [id], onDelete: Cascade)
  histories      ScheduleHistory[]

  @@map("scheduled_queries")
}

model ScheduleHistory {
  id               String         @id @default(uuid()) @db.Uuid
  scheduledQueryId String         @map("scheduled_query_id") @db.Uuid
  executedAt       DateTime       @default(now()) @map("executed_at") @db.Timestamptz
  status           String         // success, error
  errorMessage     String?        @map("error_message")
  recipientsSent   String[]       @map("recipients_sent")

  scheduledQuery   ScheduledQuery @relation(fields: [scheduledQueryId], references: [id], onDelete: Cascade)

  @@map("schedule_histories")
}
